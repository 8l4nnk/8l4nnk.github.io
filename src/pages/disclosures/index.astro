---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

type Severity = "Critical" | "High" | "Medium" | "Low" | "Info";
const allDisclosures = await getCollection("disclosures");
const disclosures = allDisclosures
	.map((e) => ({ ...e.data, slug: e.id }))
	.sort((a, b) => b.id.localeCompare(a.id));

const criticalCount = disclosures.filter(
	(d) => d.severity === "Critical",
).length;
const highCount = disclosures.filter((d) => d.severity === "High").length;
const mediumCount = disclosures.filter((d) => d.severity === "Medium").length;

const severityBg: Record<Severity, string> = {
	Critical: "bg-secondary-container text-on-secondary-fixed",
	High: "bg-primary-container/60 text-primary",
	Medium: "bg-surface-container-high text-on-surface-variant",
	Low: "bg-surface-container text-on-surface-variant",
	Info: "bg-surface-container text-on-surface-variant",
};
---

<BaseLayout title="Disclosures" description="취약점 제보 (CVE)">
	<div class="space-y-16">
		<div class="space-y-4">
			<h1 class="font-headline text-3xl md:text-5xl font-bold text-primary tracking-tight animate-fade-up">CVE Disclosures</h1>
			<p class="text-on-surface-variant font-body text-lg animate-fade-up delay-1">{disclosures.length} vulnerabilities reported.</p>
		</div>

		<div class="grid grid-cols-3 gap-3 md:gap-6 animate-fade-up delay-2">
			<div class="tonal-card bg-secondary-container p-4 md:p-8 rounded-xl text-center space-y-1 md:space-y-2">
				<div class="text-2xl md:text-3xl font-headline font-bold text-on-secondary-fixed">{criticalCount}</div>
				<div class="text-[0.6rem] md:text-xs font-label font-bold uppercase tracking-widest text-on-secondary-fixed/80">Critical</div>
			</div>
			<div class="tonal-card bg-primary-container/60 p-4 md:p-8 rounded-xl text-center space-y-1 md:space-y-2">
				<div class="text-2xl md:text-3xl font-headline font-bold text-primary">{highCount}</div>
				<div class="text-[0.6rem] md:text-xs font-label font-bold uppercase tracking-widest text-primary/80">High</div>
			</div>
			<div class="tonal-card bg-surface-container p-4 md:p-8 rounded-xl text-center space-y-1 md:space-y-2">
				<div class="text-2xl md:text-3xl font-headline font-bold text-on-surface-variant">{mediumCount}</div>
				<div class="text-[0.6rem] md:text-xs font-label font-bold uppercase tracking-widest text-on-surface-variant/80">Medium</div>
			</div>
		</div>

		<div class="bg-primary-container/30 p-6 rounded-xl animate-fade-up delay-3">
			<p class="text-on-primary-container font-body text-sm">
				<span class="font-bold">ℹ Notice:</span> Reserved 상태의 CVE는 벤더 패치 완료 후 상세 내용이 공개될 예정입니다.
			</p>
		</div>

		<div class="bg-surface-container-lowest rounded-xl p-4 md:p-14 shadow-ambient space-y-3 animate-fade-up delay-4">
			{disclosures.map((d) => {
				const isPublished = d.status === "Published";
				return (
					<div
						class:list={[
							"flex flex-wrap md:flex-nowrap items-center gap-2 md:gap-4 p-3 md:p-4 rounded-xl bg-surface-container-low/40 transition-colors",
							"hover:bg-surface-container-low group"
						]}
					>
						<a href={`https://nvd.nist.gov/vuln/detail/${d.id}`} target="_blank" rel="noopener noreferrer" class="font-mono font-bold text-xs md:text-sm text-primary shrink-0 hover:underline">{d.id}</a>
						<span class:list={["px-2 md:px-3 py-0.5 md:py-1 rounded-full text-[0.65rem] md:text-xs font-bold font-label uppercase tracking-widest shrink-0", severityBg[d.severity]]}>
							{d.severity}
						</span>
						<span class:list={[
							"px-2 md:px-3 py-0.5 md:py-1 rounded-full text-[0.65rem] md:text-xs font-bold font-label uppercase tracking-widest shrink-0",
							isPublished ? "bg-secondary-container/50 text-secondary" : "bg-surface-container text-on-surface-variant"
						]}>
							{d.status}
						</span>
					</div>
				);
			})}
		</div>
	</div>
</BaseLayout>
