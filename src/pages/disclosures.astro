---
import { disclosures, type Severity } from "../data/portfolio";
import BaseLayout from "../layouts/BaseLayout.astro";

const criticalCount = disclosures.filter(
	(d) => d.severity === "Critical",
).length;
const highCount = disclosures.filter((d) => d.severity === "High").length;
const mediumCount = disclosures.filter((d) => d.severity === "Medium").length;

const severityBg: Record<Severity, string> = {
	Critical: "bg-error-container/20 text-error",
	High: "bg-secondary-container text-on-secondary-container",
	Medium: "bg-surface-container-highest text-on-surface-variant",
	Low: "bg-surface-container text-on-surface-variant",
	Info: "bg-surface-container text-on-surface-variant",
};
---

<BaseLayout title="Disclosures" description="취약점 제보 (CVE)">
	<div class="space-y-16">
		<div class="space-y-4">
			<h1 class="font-headline text-3xl md:text-5xl font-bold text-primary tracking-tight animate-fade-up">CVE Disclosures</h1>
			<p class="text-on-surface-variant font-body text-lg animate-fade-up delay-1">{disclosures.length} vulnerabilities reported.</p>
		</div>

		<div class="grid grid-cols-3 gap-3 md:gap-6 animate-fade-up delay-2">
			<div class="tonal-card bg-error-container/10 p-4 md:p-8 rounded-xl text-center space-y-1 md:space-y-2">
				<div class="text-2xl md:text-3xl font-headline font-bold text-error">{criticalCount}</div>
				<div class="text-[0.6rem] md:text-xs font-label font-bold uppercase tracking-widest text-error/70">Critical</div>
			</div>
			<div class="tonal-card bg-secondary-container/40 p-4 md:p-8 rounded-xl text-center space-y-1 md:space-y-2">
				<div class="text-2xl md:text-3xl font-headline font-bold text-secondary">{highCount}</div>
				<div class="text-[0.6rem] md:text-xs font-label font-bold uppercase tracking-widest text-secondary/70">High</div>
			</div>
			<div class="tonal-card bg-surface-container-high p-4 md:p-8 rounded-xl text-center space-y-1 md:space-y-2">
				<div class="text-2xl md:text-3xl font-headline font-bold text-on-surface-variant">{mediumCount}</div>
				<div class="text-[0.6rem] md:text-xs font-label font-bold uppercase tracking-widest text-on-surface-variant/70">Medium</div>
			</div>
		</div>

		<div class="bg-primary-container/30 p-6 rounded-xl animate-fade-up delay-3">
			<p class="text-on-primary-container font-body text-sm">
				<span class="font-bold">ℹ Notice:</span> 모든 CVE가 예약(Reserved) 상태이며, 벤더 패치 완료 후 상세 내용이 공개될 예정입니다.
			</p>
		</div>

		<div class="bg-surface-container-lowest rounded-xl p-4 md:p-14 shadow-ambient space-y-3">
			{disclosures.map((d) => (
				<div class="flex flex-wrap md:flex-nowrap items-center gap-2 md:gap-4 p-3 md:p-4 rounded-xl bg-surface-container-low/40 hover:bg-surface-container-low transition-colors">
					<span class="font-mono font-bold text-xs md:text-sm text-primary shrink-0">{d.id}</span>
					<span class:list={["px-2 md:px-3 py-0.5 md:py-1 rounded-full text-[0.65rem] md:text-xs font-bold font-label uppercase tracking-widest shrink-0", severityBg[d.severity]]}>
						{d.severity}
					</span>
					<span class="px-2 md:px-3 py-0.5 md:py-1 bg-surface-container text-on-surface-variant rounded-full text-[0.65rem] md:text-xs font-bold font-label uppercase tracking-widest shrink-0">Reserved</span>
					<span class="text-on-surface-variant/40 text-sm font-body italic ml-auto hidden md:block">Details pending</span>
				</div>
			))}
		</div>
	</div>
</BaseLayout>
