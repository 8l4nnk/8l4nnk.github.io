---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About 8l4nk">
	<div class="space-y-16 max-w-3xl">
		<div class="space-y-4">
			<h1 class="font-headline text-3xl md:text-5xl font-bold text-primary tracking-tight animate-fade-up">About</h1>
		</div>

		<div class="space-y-6 animate-fade-up delay-1">
			<p class="text-on-surface-variant font-body text-lg leading-relaxed word-break-keep">
				해킹에 관심있는 일반인입니다.<br class="md:hidden" />
				웹 보안, 시스템 해킹, CTF 대회를 중심으로<br class="md:hidden" />
				이것저것 건드려보고 있습니다.<br class="md:hidden" />
				연락하실 사항이 있다면 연락주세요.
			</p>
		</div>

		<section class="space-y-6 animate-fade-up delay-2">
			<h2 class="font-headline text-2xl font-bold text-primary tracking-tight">Contact</h2>

			<div class="grid gap-4">
				<a href="https://github.com/8l4nnk" target="_blank" rel="noopener noreferrer"
				   class="tonal-card flex items-center gap-5 p-6 rounded-xl bg-surface-container-lowest shadow-ambient group">
					<div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center group-hover:scale-110 transition-transform">
						<svg class="w-5 h-5 text-secondary" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
					</div>
					<div>
						<div class="font-headline font-bold text-on-surface">GitHub</div>
						<div class="text-sm text-on-surface-variant font-body">github.com/8l4nnk</div>
					</div>
				</a>

				<div class="flex items-center gap-5 p-6 rounded-xl bg-surface-container-lowest shadow-ambient">
					<div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center">
						<span class="material-symbols-outlined text-on-secondary-container text-xl">mail</span>
					</div>
					<div>
						<div class="font-headline font-bold text-on-surface">Email</div>
						<div class="text-sm text-on-surface-variant font-body">sungmin7816@gmail.com</div>
					</div>
				</div>
			</div>
		</section>
	</div>
</BaseLayout>
