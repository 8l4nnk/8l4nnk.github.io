---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	disclosures,
	experience,
	achievements,
	skills,
	type Severity,
} from "../data/portfolio";

const recentCTF = achievements.filter((a) => a.type === "CTF").slice(0, 5);
const careers = experience.filter((e) => e.type === "career");

const severityColor: Record<Severity, string> = {
	Critical: "bg-red-50 text-red-600 border-red-200",
	High: "bg-orange-50 text-orange-600 border-orange-200",
	Medium: "bg-yellow-50 text-yellow-700 border-yellow-200",
	Low: "bg-blue-50 text-blue-600 border-blue-200",
	Info: "bg-stone-100 text-stone-500 border-stone-200",
};
---

<BaseLayout>
	<!-- Hero -->
	<section class="hero-grid relative overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-b from-accent/[0.08] via-accent-light/[0.03] to-transparent"></div>
		<div class="max-w-5xl mx-auto px-6 pt-20 pb-16 relative">
			<p class="text-accent-dim font-mono text-sm mb-4 animate-fade-up">Hello, I'm</p>
			<h1 class="text-5xl md:text-7xl font-bold font-mono mb-4 animate-fade-up delay-1">
				<span class="bg-gradient-to-r from-accent-dim to-accent-muted bg-clip-text text-transparent">
					8l4nk
				</span>
			</h1>
			<p class="text-xl md:text-2xl text-stone-500 mb-6 animate-fade-up delay-2">
				절 건드리면 다 부십니다
			</p>
			<p class="text-stone-400 max-w-xl leading-relaxed animate-fade-up delay-3">
				해킹에 관심있는 일반인입니다.
			</p>
		</div>
	</section>

	<!-- Stats -->
	<section class="max-w-5xl mx-auto px-6 -mt-4 mb-14">
		<div class="grid grid-cols-3 gap-4 animate-fade-up delay-3">
			<a href="/disclosures/" class="text-center p-4 rounded-xl bg-white border border-warm-border/60 shadow-sm hover:border-accent/30 transition-colors">
				<div class="text-2xl md:text-3xl font-bold font-mono text-accent-dim">{disclosures.length}</div>
				<div class="text-xs text-stone-400 mt-1">CVEs</div>
			</a>
			<a href="/achievements/" class="text-center p-4 rounded-xl bg-white border border-warm-border/60 shadow-sm hover:border-accent/30 transition-colors">
				<div class="text-2xl md:text-3xl font-bold font-mono text-accent-dim">{achievements.filter(a => a.type === "CTF").length}</div>
				<div class="text-xs text-stone-400 mt-1">CTFs</div>
			</a>
			<a href="/experience/" class="text-center p-4 rounded-xl bg-white border border-warm-border/60 shadow-sm hover:border-accent/30 transition-colors">
				<div class="text-2xl md:text-3xl font-bold font-mono text-accent-dim">{experience.length}</div>
				<div class="text-xs text-stone-400 mt-1">Experience</div>
			</a>
		</div>
	</section>

	<!-- Recent CTF -->
	<section class="max-w-5xl mx-auto px-6 mb-14">
		<div class="flex items-center justify-between mb-5">
			<div class="flex items-center gap-3">
				<span class="text-lg">🚩</span>
				<h2 class="text-lg font-semibold text-stone-700">Recent CTF</h2>
				<div class="flex-1 h-px bg-gradient-to-r from-warm-border to-transparent ml-2 w-16"></div>
			</div>
			<a href="/achievements/" class="text-xs text-accent-dim font-mono hover:text-accent-muted transition-colors">
				View all &rarr;
			</a>
		</div>
		<div class="flex flex-col gap-2.5">
			{recentCTF.map(ctf => (
				<div class="flex items-center gap-4 p-3.5 rounded-xl border border-warm-border/60 bg-white shadow-sm">
					<span class="text-xs font-mono text-stone-400 shrink-0 w-[5.5rem]">{ctf.date}</span>
					<span class="font-medium text-stone-800 text-sm">{ctf.title}</span>
					{ctf.description && (
						<span class="text-xs text-stone-400 ml-auto hidden sm:block shrink-0">{ctf.description}</span>
					)}
				</div>
			))}
		</div>
	</section>

	<!-- CVE Preview -->
	<section class="max-w-5xl mx-auto px-6 mb-14">
		<div class="flex items-center justify-between mb-5">
			<div class="flex items-center gap-3">
				<span class="text-lg">🛡</span>
				<h2 class="text-lg font-semibold text-stone-700">CVE</h2>
				<span class="text-xs text-stone-400 font-mono">{disclosures.length} reported</span>
				<div class="flex-1 h-px bg-gradient-to-r from-warm-border to-transparent ml-2 w-16"></div>
			</div>
			<a href="/disclosures/" class="text-xs text-accent-dim font-mono hover:text-accent-muted transition-colors">
				View all &rarr;
			</a>
		</div>
		<div class="p-5 rounded-xl border border-warm-border/60 bg-white shadow-sm">
			<div class="flex flex-wrap gap-2 mb-4">
				{disclosures.slice(0, 5).map(d => (
					<code class="text-xs font-mono text-accent-dim bg-accent-soft px-2 py-1 rounded-md">{d.id}</code>
				))}
				{disclosures.length > 5 && (
					<span class="text-xs text-stone-400 px-2 py-1">+{disclosures.length - 5} more</span>
				)}
			</div>
			<div class="flex gap-3 text-xs">
				<span class="px-2 py-0.5 rounded-md bg-red-50 text-red-600 border border-red-200">
					Critical {disclosures.filter(d => d.severity === "Critical").length}
				</span>
				<span class="px-2 py-0.5 rounded-md bg-orange-50 text-orange-600 border border-orange-200">
					High {disclosures.filter(d => d.severity === "High").length}
				</span>
				<span class="px-2 py-0.5 rounded-md bg-yellow-50 text-yellow-700 border border-yellow-200">
					Medium {disclosures.filter(d => d.severity === "Medium").length}
				</span>
			</div>
			<p class="text-xs text-stone-400 mt-3 italic">All CVEs currently reserved — details pending vendor patch</p>
		</div>
	</section>

	<!-- Experience Preview -->
	<section class="max-w-5xl mx-auto px-6 mb-14">
		<div class="flex items-center justify-between mb-5">
			<div class="flex items-center gap-3">
				<span class="text-lg">💼</span>
				<h2 class="text-lg font-semibold text-stone-700">Experience</h2>
				<div class="flex-1 h-px bg-gradient-to-r from-warm-border to-transparent ml-2 w-16"></div>
			</div>
			<a href="/experience/" class="text-xs text-accent-dim font-mono hover:text-accent-muted transition-colors">
				View all &rarr;
			</a>
		</div>
		<div class="flex flex-col gap-2.5">
			{careers.map(exp => (
				<div class="flex items-center gap-4 p-3.5 rounded-xl border border-warm-border/60 bg-white shadow-sm">
					<span class="text-xs font-mono text-stone-400 shrink-0">{exp.period}</span>
					<span class="font-bold text-stone-800 text-sm">{exp.organization}</span>
					{exp.role && <span class="text-xs text-stone-400">{exp.role}</span>}
				</div>
			))}
		</div>
	</section>

	<!-- Skills -->
	<section class="max-w-5xl mx-auto px-6 mb-20">
		<div class="flex items-center gap-3 mb-6">
			<h2 class="text-lg font-semibold text-stone-700">Skills</h2>
			<div class="flex-1 h-px bg-gradient-to-r from-warm-border to-transparent"></div>
		</div>
		<div class="grid sm:grid-cols-2 gap-6">
			{skills.map(group => (
				<div>
					<h3 class="text-sm font-mono text-accent-dim mb-3">{group.category}</h3>
					<div class="flex flex-wrap gap-2">
						{group.items.map(item => (
							<span class="px-3 py-1.5 rounded-lg bg-white border border-warm-border/60 text-sm text-stone-600 shadow-sm">
								{item}
							</span>
						))}
					</div>
				</div>
			))}
		</div>
	</section>
</BaseLayout>
