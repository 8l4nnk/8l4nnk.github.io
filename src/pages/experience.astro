---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experience } from "../data/portfolio";

const careers = experience.filter(e => e.type === "career");
const activities = experience.filter(e => e.type === "activity");
---

<BaseLayout title="Experience" description="경력 및 활동">
	<div class="max-w-5xl mx-auto px-6 py-12">
		<h1 class="text-3xl font-bold text-stone-800 mb-2 animate-fade-up">Experience</h1>
		<p class="text-stone-400 mb-10 animate-fade-up delay-1">
			경력 및 활동
		</p>

		<!-- 경력 -->
		{careers.length > 0 && (
			<section class="mb-12">
				<div class="flex items-center gap-3 mb-6 animate-fade-up">
					<span class="text-xl">💼</span>
					<h2 class="text-lg font-semibold text-stone-700">경력</h2>
					<div class="flex-1 h-px bg-gradient-to-r from-warm-border to-transparent"></div>
				</div>

				<div class="relative">
					<div class="absolute left-[7px] top-4 bottom-4 w-px bg-warm-border hidden md:block"></div>

					<div class="flex flex-col gap-6">
						{careers.map((exp, i) => (
							<div
								class="relative md:pl-10 animate-fade-up"
								style={`animation-delay: ${0.1 + i * 0.1}s`}
							>
								<div class="absolute left-0 top-2 w-[15px] h-[15px] rounded-full border-2 border-accent bg-warm-bg hidden md:block"></div>

								<div class="card-warm p-5 rounded-xl border border-warm-border/60 bg-white shadow-sm">
									<span class="text-sm font-mono text-accent-dim">{exp.period}</span>
									<h3 class="text-lg font-bold text-stone-800 mt-2">{exp.organization}</h3>
									{exp.role && <p class="text-sm text-stone-400">{exp.role}</p>}
									{exp.description && (
										<p class="text-sm text-stone-500 mt-3 leading-relaxed">{exp.description}</p>
									)}
									{exp.highlights.length > 0 && (
										<ul class="space-y-1.5 mt-3">
											{exp.highlights.map(h => (
												<li class="flex items-start gap-2 text-sm text-stone-500">
													<span class="text-accent-dim mt-1 shrink-0">▹</span>
													{h}
												</li>
											))}
										</ul>
									)}
								</div>
							</div>
						))}
					</div>
				</div>
			</section>
		)}

		<!-- 동아리 / 활동 -->
		{activities.length > 0 && (
			<section>
				<div class="flex items-center gap-3 mb-6 animate-fade-up">
					<span class="text-xl">🏫</span>
					<h2 class="text-lg font-semibold text-stone-700">동아리 / 활동</h2>
					<div class="flex-1 h-px bg-gradient-to-r from-warm-border to-transparent"></div>
				</div>

				<div class="flex flex-col gap-4">
					{activities.map((act, i) => (
						<div
							class="card-warm flex items-center gap-4 p-5 rounded-xl border border-warm-border/60 bg-white shadow-sm animate-fade-up"
							style={`animation-delay: ${0.15 + i * 0.1}s`}
						>
							<div class="min-w-0">
								<h3 class="font-semibold text-stone-800">{act.organization}</h3>
								<p class="text-sm text-stone-400 mt-0.5">{act.period}</p>
							</div>
						</div>
					))}
				</div>
			</section>
		)}
	</div>
</BaseLayout>
