---
import { experience } from "../data/portfolio";
import BaseLayout from "../layouts/BaseLayout.astro";

const careers = experience.filter((e) => e.type === "career");
const activities = experience.filter((e) => e.type === "activity");
---

<BaseLayout title="Experience" description="경력 및 활동">
	<div class="space-y-24">
		<div class="space-y-4">
			<h1 class="font-headline text-3xl md:text-5xl font-bold text-primary tracking-tight animate-fade-up">The Journey So Far</h1>
			<p class="text-on-surface-variant font-body text-lg animate-fade-up delay-1">경력 및 활동</p>
		</div>

		<section class="bg-surface-container-lowest rounded-xl p-6 md:p-14 shadow-ambient">
			<div class="max-w-3xl mx-auto">
				<div class="relative space-y-16">
					<div class="absolute left-6 top-0 bottom-0 w-0.5 bg-surface-container-highest rounded-full hidden md:block"></div>

					{careers.map((exp) => (
						<div class="relative flex flex-col md:flex-row gap-8 items-start">
							<div class="z-10 w-12 h-12 rounded-full bg-primary flex items-center justify-center shrink-0 shadow-lg shadow-primary/20">
								<span class="material-symbols-outlined text-white text-xl" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
							</div>
							<div class="space-y-2 pt-1">
								<div class="flex items-center gap-4 flex-wrap">
									<span class="font-headline font-bold text-2xl text-primary">{exp.organization}</span>
									<span class="px-3 py-1 bg-surface-container text-on-surface-variant rounded-full text-xs font-bold uppercase tracking-widest font-label">{exp.period}</span>
								</div>
								{exp.role && <p class="text-on-surface-variant font-body font-medium">{exp.role}</p>}
								{exp.description && <p class="text-on-surface-variant font-body leading-relaxed">{exp.description}</p>}
								{exp.highlights.length > 0 && (
									<ul class="space-y-1 pt-2">
										{exp.highlights.map(h => (
											<li class="text-on-surface-variant font-body text-sm flex items-start gap-2">
												<span class="text-primary mt-1">▹</span>{h}
											</li>
										))}
									</ul>
								)}
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		{activities.length > 0 && (
			<section class="space-y-8">
				<h2 class="font-headline text-3xl font-bold text-primary tracking-tight">Activities</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					{activities.map((act) => (
						<div class="tonal-card bg-surface-container-lowest p-8 rounded-xl shadow-ambient space-y-3">
							<div class="bg-tertiary-container/30 w-12 h-12 rounded-full flex items-center justify-center">
								<span class="material-symbols-outlined text-tertiary text-xl" style="font-variation-settings: 'FILL' 1;">school</span>
							</div>
							<h3 class="font-headline font-bold text-on-surface text-lg">{act.organization}</h3>
							{act.role && <p class="text-on-surface-variant font-body text-sm">{act.role}</p>}
							<span class="inline-block px-3 py-1 bg-surface-container text-on-surface-variant rounded-full text-xs font-bold uppercase tracking-widest font-label">{act.period}</span>
						</div>
					))}
				</div>
			</section>
		)}
	</div>
</BaseLayout>
