---
import { type AchievementType, achievements } from "../data/portfolio";
import BaseLayout from "../layouts/BaseLayout.astro";

const typeConfig: Record<AchievementType, { icon: string; bgClass: string }> = {
	CTF: { icon: "flag", bgClass: "bg-secondary" },
	Competition: { icon: "emoji_events", bgClass: "bg-primary" },
	Certification: { icon: "verified", bgClass: "bg-tertiary" },
	Award: { icon: "military_tech", bgClass: "bg-primary" },
	Publication: { icon: "article", bgClass: "bg-tertiary-dim" },
	Other: { icon: "star", bgClass: "bg-outline" },
};

const grouped = new Map<AchievementType, typeof achievements>();
for (const a of achievements) {
	if (!grouped.has(a.type)) grouped.set(a.type, []);
	grouped.get(a.type)?.push(a);
}

const typeOrder: AchievementType[] = [
	"CTF",
	"Competition",
	"Certification",
	"Award",
	"Publication",
	"Other",
];
const sortedTypes = typeOrder.filter((t) => grouped.has(t));
const typeLabel: Record<string, string> = { Competition: "경진대회" };
---

<BaseLayout title="Achievements" description="실적 및 수상 경력">
	<div class="space-y-24">
		<div class="space-y-4">
			<h1 class="font-headline text-3xl md:text-5xl font-bold text-primary tracking-tight animate-fade-up">Achievements</h1>
			<p class="text-on-surface-variant font-body text-lg animate-fade-up delay-1">CTF, 경진대회, 수상 경력</p>
		</div>

		{sortedTypes.map((type) => {
			const items = grouped.get(type)!;
			const config = typeConfig[type];
			const label = typeLabel[type] || type;
			return (
				<section class="bg-surface-container-lowest rounded-xl p-6 md:p-14 shadow-ambient">
					<div class="flex items-center gap-4 mb-10">
						<div class:list={["w-12 h-12 rounded-full flex items-center justify-center shrink-0 shadow-lg", config.bgClass, `shadow-${type === 'CTF' ? 'secondary' : 'primary'}/20`]}>
							<span class="material-symbols-outlined text-white text-xl" style="font-variation-settings: 'FILL' 1;">{config.icon}</span>
						</div>
						<div>
							<h2 class="font-headline text-2xl font-bold text-primary">{label}</h2>
							<p class="text-on-surface-variant text-sm font-body">{items.length} entries</p>
						</div>
					</div>

					<div class="grid gap-3">
						{items.map((a) => (
							<div class="p-4 rounded-xl bg-surface-container-low/50 hover:bg-surface-container-low transition-colors">
								<div class="flex items-center gap-3">
									<span class="shrink-0 w-[6.5rem] text-center px-2 py-0.5 rounded-full bg-surface-container text-on-surface-variant text-xs font-bold uppercase tracking-widest font-label">
										{a.date}
									</span>
									<span class="font-headline font-bold text-on-surface text-sm">{a.title}</span>
								</div>
								{a.description && (
									<div class="text-on-surface-variant font-body text-xs mt-1" style="margin-left: calc(6.5rem + 0.75rem)">{a.description}</div>
								)}
							</div>
						))}
					</div>
				</section>
			);
		})}
	</div>
</BaseLayout>
