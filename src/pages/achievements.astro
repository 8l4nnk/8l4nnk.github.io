---
import BaseLayout from "../layouts/BaseLayout.astro";
import { achievements, type AchievementType } from "../data/portfolio";

const typeConfig: Record<AchievementType, { color: string; icon: string }> = {
	CTF: { color: "bg-purple-50 text-purple-600 border-purple-200", icon: "🚩" },
	Competition: { color: "bg-sky-50 text-sky-600 border-sky-200", icon: "🏅" },
	Certification: {
		color: "bg-emerald-50 text-emerald-600 border-emerald-200",
		icon: "📜",
	},
	Award: { color: "bg-amber-50 text-amber-700 border-amber-200", icon: "🏆" },
	Publication: {
		color: "bg-blue-50 text-blue-600 border-blue-200",
		icon: "📄",
	},
	Other: { color: "bg-stone-100 text-stone-500 border-stone-200", icon: "📌" },
};

const grouped = new Map<AchievementType, typeof achievements>();
for (const a of achievements) {
	if (!grouped.has(a.type)) grouped.set(a.type, []);
	grouped.get(a.type)!.push(a);
}

const typeOrder: AchievementType[] = [
	"CTF",
	"Competition",
	"Certification",
	"Award",
	"Publication",
	"Other",
];
const sortedTypes = typeOrder.filter((t) => grouped.has(t));
---

<BaseLayout title="Achievements" description="실적 및 수상 경력">
	<div class="max-w-5xl mx-auto px-6 py-12">
		<h1 class="text-3xl font-bold text-stone-800 mb-2 animate-fade-up">Achievements</h1>
		<p class="text-stone-400 mb-10 animate-fade-up delay-1">
			CTF, 경진대회, 수상 경력
		</p>

		{sortedTypes.map((type) => {
			const items = grouped.get(type)!;
			const config = typeConfig[type];
			const typeLabel = type === "Competition" ? "경진대회" : type;
			return (
				<section class="mb-10 animate-fade-up">
					<div class="flex items-center gap-3 mb-5">
						<span class="text-xl">{config.icon}</span>
						<h2 class="text-lg font-semibold text-stone-700">{typeLabel}</h2>
						<span class="text-xs text-stone-400 font-mono">{items.length}</span>
						<div class="flex-1 h-px bg-gradient-to-r from-warm-border to-transparent"></div>
					</div>

					<div class="grid gap-3">
						{items.map(a => (
							<div class="card-warm flex items-start gap-4 p-4 rounded-xl border border-warm-border/60 bg-white shadow-sm">
								<div class="shrink-0 mt-0.5">
									<span class:list={[
										"inline-block px-2 py-0.5 rounded-md text-xs font-medium border font-mono",
										config.color,
									]}>
										{a.date}
									</span>
								</div>
								<div class="min-w-0">
									<h3 class="font-semibold text-stone-800 text-sm">
										{a.url ? (
											<a href={a.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent-dim transition-colors">
												{a.title}
											</a>
										) : a.title}
									</h3>
									{a.description && (
										<p class="text-sm text-stone-400 mt-0.5">{a.description}</p>
									)}
								</div>
							</div>
						))}
					</div>
				</section>
			);
		})}
	</div>
</BaseLayout>
