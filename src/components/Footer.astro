---

import { profileConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();
---

<div class="transition border-t border-black/10 dark:border-white/[0.06] my-10 border-dashed mx-32"></div>
<div class="transition rounded-2xl mb-12 flex flex-col items-center justify-center px-6">
    <div class="transition text-50 text-sm text-center font-mono">
        <span class="text-[var(--primary)] opacity-50">&gt;</span> &copy; {currentYear} {profileConfig.name} <span class="text-[var(--primary)] opacity-30">|</span>
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> <span class="text-[var(--primary)] opacity-30">|</span>
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a>
    </div>
</div>
